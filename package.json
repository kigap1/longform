{
  "name": "fact-based-ai-content-studio",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "typecheck:web": "pnpm --filter web typecheck",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload",
    "test:api": "cd apps/api && python -m unittest discover -s tests",
    "check": "pnpm typecheck:web && pnpm build:web && pnpm test:api"
  }
}
