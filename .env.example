CLAUDE_API_VERSION=2023-06-01
CLAUDE_MODEL=
CLAUDE_MAX_TOKENS=3000
CLAUDE_TEMPERATURE=0.2

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=
GEMINI_IMAGE_MODEL=
GEMINI_VIDEO_MODEL=

KLING_API_KEY=
KLING_BASE_URL=https://api-app-global.klingai.com
KLING_VIDEO_MODEL=
KLING_SUBMIT_PATH=
KLING_STATUS_PATH=
KLING_RESULT_PATH=

SCRIPT_DEFAULT_PROVIDER=openai
IMAGE_DEFAULT_PROVIDER=openai
VIDEO_DEFAULT_PROVIDER=openai
SCRIPT_PROVIDER_MODE=mock
IMAGE_PROVIDER_MODE=mock
VIDEO_PROVIDER_MODE=mock

